{
  "name": "fleet-fuel-saas",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"npm:dev -w frontend\" \"npm:dev -w backend\"",
